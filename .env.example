# 复制本文件为 .env（勿提交 .env 到 Git）
# python-dotenv 会在启动时自动加载

# ---------- 可选：OpenAI 兼容接口（本地 Ollama / 云端 key 二选一，留空则纯规则推荐）----------
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=qwen2.5:1.5b

# ---------- AI 小助手重排后端（本项目新增）----------
AI_API_HOST=127.0.0.1
AI_API_PORT=8001

# ---------- 可选：HTTP 代理（爬虫）----------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ---------- 可选：站点 Cookie（键值对 JSON 字符串，高级场景）----------
# SITE_COOKIES_JSON={}

# ---------- 可选：邮件提醒（订阅通知）----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# ---------- GitHub Actions 告警 Webhook（可选）----------
GHA_ALERT_WEBHOOK_URL=
